{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^com\\.homerail\\.topic-outline:[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": ".*\\S.*" },
    "brief": { "type": "string", "maxLength": 2000 },
    "audience": { "type": "string", "maxLength": 160 },
    "angle": { "type": "string", "maxLength": 240 },
    "thesis": { "type": "string", "maxLength": 500 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "outline": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "status": {
            "type": "string",
            "enum": ["draft", "ready", "blocked", "done"]
          },
          "points": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 1, "maxLength": 240 }
          }
        },
        "required": ["title", "status", "points"],
        "additionalProperties": false
      }
    },
    "questions": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    },
    "sources": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": ".*\\S.*" },
          "url": {
            "type": "string",
            "maxLength": 2048,
            "pattern": "^https?://[^\\s]+$"
          },
          "note": { "type": "string", "maxLength": 500 }
        },
        "required": ["title", "url"],
        "additionalProperties": false
      }
    },
    "next_action": { "type": "string", "maxLength": 240 }
  },
  "required": ["id", "title"],
  "additionalProperties": false
}
